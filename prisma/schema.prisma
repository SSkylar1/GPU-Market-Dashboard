generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MarketSnapshot {
  id               String             @id @default(cuid())
  source           String
  ingestMode       String?
  sourceQueryHash  String?
  sourceQuery      Json?
  capturedAt       DateTime           @default(now())
  createdAt        DateTime           @default(now())
  offers           Offer[]
  rollups          GpuRollup[]
  trendAggregates  GpuTrendAggregate[]
  churnAggregates  GpuChurnAggregate[]

  @@index([capturedAt])
  @@index([sourceQueryHash])
}

model Offer {
  id               String   @id @default(cuid())
  snapshotId       String
  offerId          String
  hostId           Int?
  machineId        Int?
  gpuName          String
  numGpus          Int      @default(1)
  offerType        String?
  gpuRamGb         Int?
  cpuCores         Int?
  ramGb            Int?
  diskGb           Int?
  inetUpMbps       Float?
  inetDownMbps     Float?
  rentable         Boolean  @default(false)
  rented           Boolean  @default(false)
  verified         Boolean?
  reliabilityScore Float?
  pricePerHour     Float?
  rawJson          Json?
  createdAt        DateTime @default(now())

  snapshot MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([gpuName])
  @@index([gpuName, numGpus, offerType])
  @@index([offerId])
  @@index([hostId])
  @@index([machineId])
  @@index([rentable])
  @@index([rented])
}

model GpuChurnAggregate {
  id                    String   @id @default(cuid())
  snapshotId            String
  previousSnapshotId    String
  source                String
  sourceQueryHash       String?
  gpuName               String
  numGpus               Int
  offerType             String   @default("unknown")
  bucketStartUtc        DateTime
  newOfferCount         Int
  disappearedOfferCount Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  snapshot MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([bucketStartUtc])
  @@index([gpuName, bucketStartUtc])
  @@index([sourceQueryHash, bucketStartUtc])
  @@unique([source, gpuName, numGpus, offerType, bucketStartUtc])
}

model GpuRollup {
  id                 String   @id @default(cuid())
  snapshotId         String
  gpuName            String
  numGpus            Int      @default(1)
  offerType          String   @default("unknown")
  totalOffers        Int
  rentableOffers     Int
  rentedOffers       Int
  impliedUtilization Float
  minPrice           Float?
  p10Price           Float?
  medianPrice        Float?
  p90Price           Float?
  createdAt          DateTime @default(now())

  snapshot MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([gpuName, numGpus, offerType])
  @@unique([snapshotId, gpuName, numGpus, offerType])
}

model GpuTrendAggregate {
  id                 String   @id @default(cuid())
  snapshotId         String
  source             String
  gpuName            String
  numGpus            Int      @default(1)
  offerType          String   @default("unknown")
  bucketStartUtc     DateTime
  snapshotCount      Int
  totalOffers        Int
  rentableOffers     Int
  rentedOffers       Int
  impliedUtilization Float
  availabilityRatio  Float
  minPrice           Float?
  p10Price           Float?
  medianPrice        Float?
  p90Price           Float?
  newOfferCount      Int?
  disappearedOfferCount Int?
  newOfferRate       Float?
  disappearedRate    Float?
  netSupplyChange    Int?
  medianPriceChange  Float?
  rentableShareChange Float?
  marketPressureScore Float?
  marketPressurePriceComponent Float?
  marketPressureChurnComponent Float?
  marketPressureSupplyComponent Float?
  marketPressureAvailabilityComponent Float?
  lowBandDisappearedCount Int?
  midBandDisappearedCount Int?
  highBandDisappearedCount Int?
  lowBandDisappearedRate Float?
  midBandDisappearedRate Float?
  highBandDisappearedRate Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  snapshot MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([bucketStartUtc])
  @@index([gpuName, numGpus, offerType, bucketStartUtc])
  @@unique([gpuName, numGpus, offerType, bucketStartUtc, source])
}

model HardwareScenario {
  id                    String   @id @default(cuid())
  gpuName               String
  gpuCount              Int
  assumedPowerWatts     Int
  assumedHardwareCost   Float
  electricityCostPerKwh Float
  targetPaybackMonths   Int
  notes                 String?
  createdAt             DateTime @default(now())

  scores ScenarioScore[]

  @@index([gpuName])
}

model ScenarioScore {
  id                     String   @id @default(cuid())
  scenarioId             String
  demandScore            Float
  competitionScore       Float
  priceStrengthScore     Float
  efficiencyScore        Float
  overallScore           Float
  recommendation         String
  recommendedPriceLow    Float?
  recommendedPriceTarget Float?
  recommendedPriceHigh   Float?
  createdAt              DateTime @default(now())

  scenario HardwareScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}
