generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MarketSnapshot {
  id               String             @id @default(cuid())
  source           String
  ingestMode       String?
  sourceQueryHash  String?
  sourceQuery      Json?
  capturedAt       DateTime           @default(now())
  createdAt        DateTime           @default(now())
  offers           Offer[]
  rollups          GpuRollup[]
  trendAggregates  GpuTrendAggregate[]
  churnAggregates  GpuChurnAggregate[]

  @@index([capturedAt])
  @@index([sourceQueryHash])
}

model Offer {
  id                     String   @id @default(cuid())
  snapshotId             String
  source                 String
  capturedAt             DateTime
  offerId                String
  offerExternalId        String?
  offerFingerprint       String?
  stableOfferFingerprint String?
  versionFingerprint     String?
  identityStrategy       String?
  identityQualityScore   Float?
  hostId                 Int?
  machineId              Int?
  gpuName                String
  numGpus                Int      @default(1)
  offerType              String?
  gpuRamGb               Int?
  cpuCores               Int?
  ramGb                  Int?
  diskGb                 Int?
  inetUpMbps             Float?
  inetDownMbps           Float?
  rentable               Boolean  @default(false)
  rented                 Boolean  @default(false)
  verified               Boolean?
  reliabilityScore       Float?
  pricePerHour           Float?
  dlperf                 Float?
  timeRemaining          Float?
  geolocation            Json?
  relativePriceToCohort  Float?
  rawJson                Json?
  createdAt              DateTime @default(now())

  snapshot MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([source, capturedAt])
  @@index([gpuName])
  @@index([gpuName, numGpus, offerType])
  @@index([offerId])
  @@index([offerExternalId])
  @@index([offerFingerprint])
  @@index([stableOfferFingerprint])
  @@index([versionFingerprint])
  @@index([hostId])
  @@index([machineId])
  @@index([rentable])
  @@index([rented])
}

model OfferLifecycle {
  id                             String   @id @default(cuid())
  source                         String
  offerFingerprint               String
  stableOfferFingerprint         String?
  latestVersionFingerprint       String?
  identityStrategy               String?
  identityQualityScore           Float?
  offerExternalId                String?
  gpuName                        String
  numGpus                        Int
  offerType                      String
  machineId                      Int?
  hostId                         Int?
  firstSeenAt                    DateTime
  lastSeenAt                     DateTime
  totalVisibleSnapshots          Int
  seenCount                      Int?
  totalVisibleHours              Float
  cumulativeVisibleMinutes       Float?
  offerSeenSpanMinutes           Float?
  disappearanceCount             Int
  reappearanceCount              Int
  firstMissingAt                 DateTime?
  reappearedAt                   DateTime?
  gapDurationMinutes             Float?
  visibilitySegmentCount         Int?
  longestContinuousVisibleHours  Float
  estimatedConsumedAt            DateTime?
  insufficientObservation        Boolean?
  latestKnownPricePerHour        Float?
  latestKnownReliabilityScore    Float?
  firstKnownPricePerHour         Float?
  minObservedPricePerHour        Float?
  maxObservedPricePerHour        Float?
  priceEditCount                 Int
  mutationCount                  Int @default(0)
  lastStatus                     String
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
  segments                       OfferLifecycleSegment[]

  @@unique([source, offerFingerprint])
  @@index([source, gpuName, numGpus, offerType, firstSeenAt])
}

model OfferLifecycleSegment {
  id                String   @id @default(cuid())
  lifecycleId       String
  segmentStartAt    DateTime
  segmentEndAt      DateTime?
  durationHours     Float?
  endedBy           String
  startPricePerHour Float?
  endPricePerHour   Float?
  medianPricePerHour Float?
  startRentable     Boolean?
  endRentable       Boolean?
  createdAt         DateTime @default(now())

  lifecycle OfferLifecycle @relation(fields: [lifecycleId], references: [id], onDelete: Cascade)

  @@index([lifecycleId, segmentStartAt])
}

model GpuChurnAggregate {
  id                    String   @id @default(cuid())
  snapshotId            String
  previousSnapshotId    String
  source                String
  sourceQueryHash       String?
  gpuName               String
  numGpus               Int
  offerType             String   @default("unknown")
  bucketStartUtc        DateTime
  newOfferCount         Int
  disappearedOfferCount Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  snapshot MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([bucketStartUtc])
  @@index([gpuName, bucketStartUtc])
  @@index([sourceQueryHash, bucketStartUtc])
  @@unique([source, gpuName, numGpus, offerType, bucketStartUtc])
}

model GpuRollup {
  id                 String   @id @default(cuid())
  snapshotId         String
  gpuName            String
  numGpus            Int      @default(1)
  offerType          String   @default("unknown")
  totalOffers        Int
  rentableOffers     Int
  rentedOffers       Int
  impliedUtilization Float
  minPrice           Float?
  p10Price           Float?
  medianPrice        Float?
  p90Price           Float?
  createdAt          DateTime @default(now())

  snapshot MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([gpuName, numGpus, offerType])
  @@unique([snapshotId, gpuName, numGpus, offerType])
}

model GpuTrendAggregate {
  id                                 String   @id @default(cuid())
  snapshotId                         String
  source                             String
  cohortKey                          String
  gpuName                            String
  numGpus                            Int?
  offerType                          String?
  bucketStartUtc                     DateTime
  snapshotCount                      Int
  totalOffers                        Int
  uniqueMachines                     Int?
  uniqueHosts                        Int?
  rentableOffers                     Int
  rentedOffers                       Int
  continuingOffers                   Int?
  newOffers                          Int?
  disappearedOffers                  Int?
  reappearedOffers                   Int?
  persistentDisappearedOffers        Int?
  newOfferRate                       Float?
  disappearedRate                    Float?
  reappearedRate                     Float?
  persistentDisappearanceRate        Float?
  machineEntryRate                   Float?
  machineExitRate                    Float?
  hostEntryRate                      Float?
  hostExitRate                       Float?
  impliedUtilization                 Float
  availabilityRatio                  Float
  minPrice                           Float?
  p10Price                           Float?
  medianPrice                        Float?
  p90Price                           Float?
  maxPrice                           Float?
  priceCv                            Float?
  medianPriceChange                  Float?
  lowBandDisappearedRate             Float?
  midBandDisappearedRate             Float?
  highBandDisappearedRate            Float?
  lowBandPersistentDisappearedRate   Float?
  midBandPersistentDisappearedRate   Float?
  highBandPersistentDisappearedRate  Float?
  supplyTightnessScore               Float?
  movementScore                      Float?
  machineDepthScore                  Float?
  concentrationScore                 Float?
  cohortPressureScore                Float?
  pressureAcceleration               Float?
  pressurePersistence                Float?
  state                              String?
  stateConfidence                    Float?
  timeDepthScore                     Float?
  crossSectionDepthScore             Float?
  dataDepthScore                     Float?
  noiseScore                         Float?
  configVsFamilyPressureDelta        Float?
  configVsFamilyPriceDelta           Float?
  configVsFamilyHazardDelta          Float?
  machineConcentrationShareTop1      Float?
  machineConcentrationShareTop3      Float?
  hostConcentrationShareTop1         Float?
  hostConcentrationShareTop3         Float?
  machinePersistenceRate             Float?
  hostPersistenceRate                Float?
  newMachineEntryRate                Float?
  disappearingMachineRate            Float?
  temporaryMissingRate               Float?
  reappearedShortGapRate             Float?
  reappearedLongGapRate              Float?
  medianReappearanceDelayBuckets     Float?
  persistentDisappearanceRateN       Float?
  churnAdjustedDisappearanceRate     Float?
  churnScore                         Float?
  signalStrengthScore                Float?
  inferabilityScore                  Float?
  identityQualityScore               Float?
  observationCount                   Int?
  observationsPerOffer               Float?
  medianPollGapMinutes               Float?
  maxPollGapMinutes                  Float?
  coverageRatio                      Float?
  offerSeenSpanMinutes               Float?
  cohortObservationDensityScore      Float?
  labelabilityScore                  Float?
  futureWindowCoverage12h            Float?
  futureWindowCoverage24h            Float?
  futureWindowCoverage72h            Float?
  samplingQualityScore               Float?
  lifecycleObservabilityScore        Float?
  insufficientSampling               Boolean?
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt

  snapshot MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([bucketStartUtc])
  @@index([source, gpuName, bucketStartUtc])
  @@index([source, gpuName, numGpus, offerType, bucketStartUtc])
  @@unique([source, cohortKey, bucketStartUtc])
}

model CohortForecast {
  id                         String   @id @default(cuid())
  source                     String
  gpuName                    String
  numGpus                    Int?
  offerType                  String?
  bucketStartUtc             DateTime
  forecastHorizonHours       Int
  pTight                     Float
  pBalanced                  Float
  pOversupplied              Float
  pPriceUp                   Float
  pPriceFlat                 Float
  pPriceDown                 Float
  expectedPressure           Float
  expectedPressureLow        Float
  expectedPressureHigh       Float
  expectedVisibleSupply      Float
  expectedVisibleSupplyLow   Float
  expectedVisibleSupplyHigh  Float
  expectedMedianPrice        Float?
  expectedMedianPriceLow     Float?
  expectedMedianPriceHigh    Float?
  confidenceScore            Float
  calibrationVersion         String
  modelVersion               String
  createdAt                  DateTime @default(now())

  @@index([source, gpuName, bucketStartUtc])
  @@index([source, gpuName, numGpus, offerType, bucketStartUtc])
  @@unique([source, gpuName, numGpus, offerType, bucketStartUtc, forecastHorizonHours, modelVersion])
}

model HardwareScenario {
  id                    String   @id @default(cuid())
  gpuName               String
  gpuCount              Int
  assumedPowerWatts     Int
  assumedHardwareCost   Float
  electricityCostPerKwh Float
  targetPaybackMonths   Int
  notes                 String?
  createdAt             DateTime @default(now())

  scores            ScenarioScore[]
  scenarioForecasts ScenarioForecast[]

  @@index([gpuName])
}

model ScenarioScore {
  id                     String   @id @default(cuid())
  scenarioId             String
  demandScore            Float
  competitionScore       Float
  priceStrengthScore     Float
  efficiencyScore        Float
  overallScore           Float
  recommendation         String
  recommendedPriceLow    Float?
  recommendedPriceTarget Float?
  recommendedPriceHigh   Float?
  createdAt              DateTime @default(now())

  scenario HardwareScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}

model ScenarioForecast {
  id                                     String   @id @default(cuid())
  hardwareScenarioId                     String
  modelVersion                           String
  source                                 String
  gpuName                                String
  numGpus                                Int?
  offerType                              String?
  createdAt                              DateTime @default(now())
  pUtilizationAbove25                    Float
  pUtilizationAbove50                    Float
  pUtilizationAbove75                    Float
  expectedUtilization                    Float
  expectedUtilizationLow                 Float
  expectedUtilizationHigh                Float
  expectedDailyRevenue                   Float
  expectedDailyRevenueLow                Float
  expectedDailyRevenueHigh               Float
  expectedDailyMargin                    Float
  expectedDailyMarginLow                 Float
  expectedDailyMarginHigh                Float
  expectedPaybackMonths                  Float?
  expectedPaybackMonthsLow               Float?
  expectedPaybackMonthsHigh              Float?
  pPaybackWithinTarget                   Float
  pScenarioOutperformingGpuFamilyMedian  Float
  confidenceScore                        Float
  recommendation                         String
  recommendationReasonPrimary            String
  recommendationReasonSecondary          String
  riskFlags                              Json
  explanation                            Json

  scenario HardwareScenario @relation(fields: [hardwareScenarioId], references: [id], onDelete: Cascade)

  @@index([hardwareScenarioId])
  @@index([source, gpuName, createdAt])
}

model ForecastBacktest {
  id                       String   @id @default(cuid())
  source                   String
  gpuName                  String
  numGpus                  Int?
  offerType                String?
  predictionBucketStartUtc DateTime
  horizonHours             Int
  predictedPTight          Float
  realizedTight            Boolean
  predictedPPriceUp        Float
  realizedPriceUp          Boolean
  predictedConsumptionProb Float
  predictedConsumptionProbRaw Float?
  predictedConsumptionProbCalibrated Float?
  realizedConsumption      Boolean
  realizedConsumptionLegacy Boolean?
  consumptionLabelCensored Boolean @default(false)
  consumptionLabelQuality   String?
  timeToReappearanceBuckets Float?
  timeToReappearanceHours  Float?
  realizedConsumedWithin12h Boolean?
  realizedConsumedWithin24h Boolean?
  realizedConsumedWithin72h Boolean?
  realizedTightSustained   Boolean?
  confidenceBucket         String?
  inferabilityBucket       String?
  stateAtPrediction        String?
  calibrationBucket        String
  modelVersion             String
  createdAt                DateTime @default(now())

  @@index([source, gpuName, predictionBucketStartUtc])
  @@index([source, gpuName, numGpus, offerType, horizonHours])
}
